{
  "name": "miuiga",
  "version": "1.0.0",
  "description": "Make Internet UI Great Again (MIUIGA) - A retro React component library.",
  "type": "module",
  "main": "./dist/miuiga.umd.cjs",
  "module": "./dist/miuiga.js",
  "types": "./dist/index.d.ts",
